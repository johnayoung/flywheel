# Flywheel runtime state — ignore everything under .flywheel/ except the
# user-authored task definitions in .flywheel/tasks/.
.flywheel/*
!.flywheel/tasks/

# Go build artifacts
/bin/
*.exe
*.test
*.out

# Coverage
coverage.html
coverage.out

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Temp
*.tmp
*.log
tmp/