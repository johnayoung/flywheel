{
  "version": "1",
  "repo": ".",
  "base_ref": "main",
  "branch_prefix": "flywheel/",
  "max_parallel": 3,
  "build_command": "go build ./...",
  "store": {
    "backend": "jsonl",
    "tasks_path": "./tasks",
    "lifecycle_path": "./.flywheel/lifecycle"
  },
  "merge_strategy": "sequential",
  "review": "agent",
  "agent": "claude-code",
  "timeout": "30m",
  "max_retries": 2,
  "max_resolve_attempts": 2
}
